# ============================================
# Voice Calling Agent - Environment Configuration
# ============================================

# --- Server ---
HOST=0.0.0.0
PORT=8000
ENV=production
LOG_LEVEL=INFO
CORS_ORIGINS=*

# --- SIP account (direct PJSIP/pjsua2 client) ---
# Your softphone-style account. Domain is the SIP server "host:port".
SIP_DOMAIN=15.207.28.98:7719
SIP_USERNAME=1055
SIP_PASSWORD=change-me
SIP_TRANSPORT=udp
# Local UDP/TCP port the agent binds for SIP signalling.
SIP_LOCAL_PORT=5060
# Outbound number formatting for the PBX dialplan.
#   This PBX routes the 10-digit national number and 404s the country-code form,
#   so strip the leading country code. Add a prefix here if your trunk needs one.
SIP_DIAL_STRIP_CC=91
SIP_DIAL_PREFIX=

# --- MongoDB (OPTIONAL) ---
# Leave MONGO_URL blank to run without a database: agents load from
# config/agents/*.json and transcripts are not persisted. Set a connection URI
# to enable persisted agents + call/transcript history.
MONGO_URL=
MONGO_DB=voice_agent
# Where file-based agents live when there's no DB.
AGENTS_DIR=config/agents

# --- Vector store: embeddings live in MongoDB (no separate service needed) ---

# --- OpenAI (LLM + Whisper STT + OpenAI TTS — the whole AI pipeline) ---
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# --- Deepgram (streaming STT) ---
DEEPGRAM_API_KEY=

# --- ElevenLabs (natural TTS voice) ---
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_flash_v2_5

# --- Storage ---
UPLOAD_DIR=./uploads

# --- Webhooks ---
WEBHOOK_SECRET=replace-with-strong-random-string

# Max recent conversation messages sent to the LLM per turn (caps long-call cost/latency)
LLM_HISTORY_MESSAGES=20
